# Database
DATABASE_URL=postgres://tileserp:CHANGE_ME@db:5432/tileserp

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_RANDOM_64_CHARS
