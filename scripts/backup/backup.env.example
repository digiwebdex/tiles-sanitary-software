# ============================================================
# TilesERP Automated Backup System - Environment Configuration
# Copy to /opt/tileserp-backup/.env and fill in values
# ============================================================

# ── Notification ──────────────────────────────────────────────
NOTIFY_EMAIL="bditengineer@gmail.com"
SERVER_NAME="TilesERP-VPS"
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# ── Google Drive (rclone) ────────────────────────────────────
RCLONE_REMOTE="gdrive"
GDRIVE_ROOT_FOLDER="TilesERP-Backups"

# ── PostgreSQL (main app DB) ─────────────────────────────────
PG_ENABLED="true"
PG_HOST="127.0.0.1"
PG_PORT="5440"
PG_USER="postgres"
PG_PASSWORD="YOUR_PG_PASSWORD"
PG_DATABASES="tilessaas"
PG_APP_NAME="tilessaas"

# ── MySQL / MariaDB (if any Coolify apps use it) ─────────────
MYSQL_ENABLED="false"
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="YOUR_MYSQL_PASSWORD"
MYSQL_DATABASES=""
MYSQL_APP_NAME="coolify-app"

# ── MongoDB (if any Coolify apps use it) ──────────────────────
MONGO_ENABLED="false"
MONGO_HOST="127.0.0.1"
MONGO_PORT="27017"
MONGO_USER=""
MONGO_PASSWORD=""
MONGO_AUTH_DB="admin"
MONGO_DATABASES=""
MONGO_APP_NAME="coolify-app"

# ── Retention ─────────────────────────────────────────────────
# Keep only the most recent backup — delete anything older than 1 day
# (both locally and on Google Drive)
RETENTION_DAILY_DAYS="1"
RETENTION_WEEKLY_WEEKS="0"

# ── Paths ─────────────────────────────────────────────────────
BACKUP_BASE_DIR="/opt/tileserp-backup/data"
LOG_DIR="/opt/tileserp-backup/logs"
TEMP_DIR="/opt/tileserp-backup/tmp"

# ── Supabase API (for logging backups to dashboard) ──────────
SUPABASE_URL="https://wvpojbdlrkspojotspip.supabase.co"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
